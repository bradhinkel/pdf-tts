# Azure TTS
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=en-US-AriaNeural

# Storage — omit locally (defaults to app/pdfs/ next to source); set for production
# PDF_STORAGE_PATH=/opt/pdf-tts/pdfs

# XTTS-v2 (V1.5 experiment — only needed if using ?tts=xtts)
# XTTS_SPEAKER=Ana Florence
# TTS_HOME=/opt/pdf-tts/models
MAX_PDF_SIZE=100000000
